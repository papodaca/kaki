#: data/org.kaki.app.desktop.in:8
msgid "GTK;"
msgstr ""

#: data/org.kaki.app.gschema.xml:6
msgid "Path to the GGUF model file used for local transcription"
msgstr ""

#: data/org.kaki.app.gschema.xml:7
msgid ""
"Absolute path to a Whisper-compatible GGUF model. When empty, Kaki scans "
"~/.local/share/kaki/models/ for the first *.gguf at startup."
msgstr ""

#: data/org.kaki.app.gschema.xml:11
msgid "Use streaming transcription when available"
msgstr ""

#: data/org.kaki.app.gschema.xml:12
msgid ""
"When true and the loaded model supports streaming, partial transcripts are "
"emitted while speaking. When false, the whole clip is transcribed after stop."
msgstr ""

#: data/org.kaki.app.gschema.xml:16
msgid "Language code or 'auto' for detection"
msgstr ""

#: data/org.kaki.app.gschema.xml:17
msgid ""
"ISO-639-1 language code passed to the transcribe runtime, or \"auto\" to let "
"the model detect the language."
msgstr ""

#: data/org.kaki.app.gschema.xml:21
msgid "Number of CPU threads for the transcribe.cpp runtime"
msgstr ""

#: data/org.kaki.app.gschema.xml:22
msgid ""
"Thread count passed to SessionParams.n_threads. Ignored on GPU backends that "
"don't use CPU threads."
msgstr ""

#: data/org.kaki.app.gschema.xml:26
msgid "Auto-type streamed text into focused window during dictation"
msgstr ""

#: data/org.kaki.app.gschema.xml:27
msgid ""
"When true, the streamed transcript is injected via the keystroke backend "
"into whatever window has keyboard focus while Kaki is minimized. When false, "
"dictation records and transcribes but does not inject keystrokes."
msgstr ""

#: data/org.kaki.app.gschema.xml:31
msgid "Delay between keystrokes when simulating typing (ms)"
msgstr ""

#: data/org.kaki.app.gschema.xml:32
msgid ""
"Passed to ydotool (--key-delay) or xdotool (--delay). Ignored by the libei "
"backend, which injects events directly."
msgstr ""

#: data/org.kaki.app.gschema.xml:36
msgid "Append a newline after each dictation session"
msgstr ""

#: data/org.kaki.app.gschema.xml:37
msgid ""
"When true, a newline is typed after the final transcript of each dictation "
"session. Useful when dictating into a chat composer that sends on Enter."
msgstr ""

#: data/org.kaki.app.gschema.xml:41
msgid "Keystroke injection backend: auto|libei|ydotool|xdotool"
msgstr ""

#: data/org.kaki.app.gschema.xml:42
msgid ""
"Forces a specific backend. \"auto\" picks libei (if built with support) then "
"ydotool then xdotool based on availability and session type."
msgstr ""

#: data/org.kaki.app.gschema.xml:47
msgid ""
"Preferred GPU backend (read-only at runtime; reflects the build-time choice)"
msgstr ""

#: data/org.kaki.app.gschema.xml:48
msgid ""
"The resolved backend baked into the binary at build time (auto / hip / "
"vulkan / cpu). Read-only at runtime; the binary was linked against one "
"backend only."
msgstr ""

#: data/org.kaki.app.gschema.xml:52
msgid "Enable flash-attention for the local Whisper model"
msgstr ""

#: data/org.kaki.app.gschema.xml:53
msgid ""
"When true, transcribe.cpp session.run is invoked with flash attention "
"enabled. May improve performance on supported models."
msgstr ""

#: data/org.kaki.app.gschema.xml:57
msgid "Transcription source: local|api"
msgstr ""

#: data/org.kaki.app.gschema.xml:58
msgid ""
"\"local\" uses the GGUF model on disk. \"api\" sends audio to an OpenAI-"
"compatible endpoint (see api-* keys)."
msgstr ""

#: data/org.kaki.app.gschema.xml:62
msgid "OpenAI-compatible transcription endpoint URL"
msgstr ""

#: data/org.kaki.app.gschema.xml:63
msgid ""
"POSTed multipart/form-data with the captured WAV. Defaults to OpenAI; point "
"at any OpenAI-compatible server."
msgstr ""

#: data/org.kaki.app.gschema.xml:67
msgid "Model name sent to the transcription API"
msgstr ""

#: data/org.kaki.app.gschema.xml:68
msgid ""
"The \"model\" form field passed to the endpoint. Defaults to OpenAI's "
"whisper-1."
msgstr ""

#: data/org.kaki.app.gschema.xml:72
msgid "Response format requested from the transcription API"
msgstr ""

#: data/org.kaki.app.gschema.xml:73
msgid ""
"One of \"json\", \"text\", or \"verbose_json\". Sent as the "
"\"response_format\" form field when supported by the endpoint."
msgstr ""

#: data/org.kaki.app.gschema.xml:77
msgid "Sampling temperature for the transcription API (0.0–1.0)"
msgstr ""

#: data/org.kaki.app.gschema.xml:78
msgid ""
"Passed as the \"temperature\" form field. 0.0 is deterministic; 1.0 is "
"maximum randomness."
msgstr ""

#: data/org.kaki.app.gschema.xml:82
msgid "Request English translation from the API"
msgstr ""

#: data/org.kaki.app.gschema.xml:83
msgid ""
"When true, sends \"translate=true\" so the API returns an English transcript "
"of whatever language was spoken."
msgstr ""

#: data/org.kaki.app.gschema.xml:87
msgid "Accelerator for win.record"
msgstr ""

#: data/org.kaki.app.gschema.xml:88 data/org.kaki.app.gschema.xml:93
